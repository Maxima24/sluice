{
  "name": "fiber-liquidity-layer",
  "version": "0.0.1",
  "private": true,
  "description": "Fiber Liquidity Layer — operability tooling for a CKB Fiber Network node (monorepo)",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:backend": "pnpm --filter backend run dev",
    "dev:frontend": "pnpm --filter frontend run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "prisma:migrate": "pnpm --filter backend run prisma:migrate",
    "prisma:generate": "pnpm --filter backend run prisma:generate"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "@tailwindcss/oxide",
      "sharp",
      "unrs-resolver"
    ]
  }
}
