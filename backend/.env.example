# ── Fiber Liquidity Layer — backend env ─────────────────────────────────────
# Copy to `.env` and fill in. Validated at boot (fail-fast) by src/config/env.schema.ts.

# Runtime
NODE_ENV=development
# Render injects PORT in production; locally we default to 3000.
PORT=3000
# Comma-separated allowed origins, or "*" for all (dev). Set to the frontend origin in prod.
CORS_ORIGINS=*

# Postgres (Render Postgres URL in prod; local dev via infra/docker-compose.deps.yml)
# NOTE: use 127.0.0.1 (not "localhost") to force IPv4; pick a host port that does
# not collide with any native Postgres install (e.g. 5433 -> container 5432).
DATABASE_URL=postgresql://fiber:fiber@127.0.0.1:5433/fiber?schema=public

# ── Fiber node (FNN) — REQUIRED ─────────────────────────────────────────────
# JSON-RPC over HTTP. Local dev reaches the FNN node via the socat proxy on 8299
# (the node keeps RPC on its secure default 127.0.0.1:8227 — see infra/README.md).
FIBER_RPC_URL=http://127.0.0.1:8299
# WebSocket subscriptions — FNN serves HTTP + WS on the same port (via the same proxy).
FIBER_WS_URL=ws://127.0.0.1:8299
# Per-call RPC timeout in milliseconds.
FIBER_RPC_TIMEOUT_MS=10000

# ── Realtime / worker (used from Step 4 / Step 6) ───────────────────────────
# Low-frequency list_channels poll — the drift-proof source of channel-balance truth.
POLL_INTERVAL_MS=15000
# Redis for BullMQ — required for /rebalance (Step 6). Render Key Value / Upstash URL in prod.
REDIS_URL=redis://127.0.0.1:6379
# Run the rebalance worker embedded in this process (true) or as a standalone worker (false).
RUN_WORKER_INLINE=true
# Demo aid: true = simulate a settled rebalance (no node call, no funds moved) so the full
# lifecycle + double-entry ledger are demoable without on-chain liquidity; false = real settlement.
REBALANCE_SIMULATE=false

# ── Security gate — break-glass fallback for mutating calls ─────────────────
# If set, mutating calls may send `X-Dashboard-Secret: <value>`. Leave unset in dev.
# DASHBOARD_SECRET=

# ── Operator wallet sign-in (Sign-In-With-CKB via CCC) ──────────────────────
# Allowlist of "<signType>:<identity>" operator keys (comma-separated). When set,
# mutating endpoints require a wallet session. On first sign-in the API returns a
# 403 echoing your exact key — paste it here. e.g. JoyId:{"publicKey":"0x..."}
# OPERATOR_KEYS=
# HMAC secret for the session JWT — REQUIRED once OPERATOR_KEYS is set or AUTH_OPEN=true.
# AUTH_JWT_SECRET=
# Session lifetime in hours (default 12).
# AUTH_SESSION_TTL_H=12
# Open mode: true = ANY wallet that signs in may operate (demo); false = restrict to OPERATOR_KEYS.
# AUTH_OPEN=false
